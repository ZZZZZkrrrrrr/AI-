{
  "schemaVersion": "store-screenshot-plan-v1",
  "updatedAt": "2026-06-09",
  "officialReferences": [
    {
      "name": "Apple screenshot specifications",
      "url": "https://developer.apple.com/help/app-store-connect/reference/screenshot-specifications/"
    },
    {
      "name": "Google Play preview asset guidelines",
      "url": "https://support.google.com/googleplay/android-developer/answer/9866151"
    }
  ],
  "capturePrinciples": [
    "Use real app screens from the production build, not marketing-only slides.",
    "Show the mobile app value path in the first shots: video-mode home, image/text-mode home, prompt-package guided entry, create, task/assets, settings/compliance.",
    "Keep text legible on 390px phones and avoid overlays that hide real UI.",
    "Do not show real API keys, private customer assets, unfinished TODO URLs, or personal data.",
    "Use localized screenshot sets for the markets submitted."
  ],
  "requiredScenes": [
    "home",
    "home-image",
    "create-prompt-intent",
    "create",
    "assets",
    "settings",
    "stitch"
  ],
