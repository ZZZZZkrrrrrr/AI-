  "notLegalAdvice": true,
  "officialBasis": [
    {
      "name": "Apple App Privacy Details",
      "url": "https://developer.apple.com/app-store/app-privacy-details/",
      "requirement": "App Store Connect privacy answers must identify data collected by the app and third-party partners, whether data is linked to users, and whether data is used for tracking."
    },
    {
      "name": "Apple App Review Guidelines 5.1 Privacy",
      "url": "https://developer.apple.com/app-store/review/guidelines/",
      "requirement": "The app metadata and in-app surfaces must include an accessible privacy policy that clearly identifies collected data, collection methods, use, and third-party sharing."
    },
    {
      "name": "Google Play Data safety section",
      "url": "https://support.google.com/googleplay/android-developer/answer/10787469",
      "requirement": "Play Console declarations must disclose collected/shared data, security practices, deletion mechanisms, and third-party code behavior."
    },
    {
      "name": "Google Play User Data policy",
      "url": "https://support.google.com/googleplay/android-developer/answer/10144311",
      "requirement": "Personal and sensitive user data must be limited to app and service functionality, transmitted securely, and covered by required disclosures and permissions."
    },
    {
      "name": "Google Play app account deletion requirements",
      "url": "https://support.google.com/googleplay/android-developer/answer/13327111",
      "requirement": "Apps with account creation must provide both an in-app path and a public web link where users can request account and associated data deletion."
    },
    {
      "name": "CAC AI-generated synthetic content labeling measures",
      "url": "https://www.cac.gov.cn/2025-03/14/c_1743654684782215.htm",
      "requirement": "China-facing AI-generated content workflows need legal review for visible or implicit AI content labeling obligations."
    }
  ],
