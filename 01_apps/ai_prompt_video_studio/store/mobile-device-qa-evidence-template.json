    {
      "name": "web.dev PWA installation",
      "url": "https://web.dev/learn/pwa/installation",
      "appliesTo": [
        "android-pwa",
        "ios-pwa"
      ]
    }
  ],
  "evidenceRules": {
    "repositoryPolicy": "Only sanitized screenshots, redacted notes, command summaries, and test-result JSON files may be committed.",
    "doNotStore": [
      "real review account password",
      "session cookies",
      "API keys",
      "signing certificates or keystores",
      "private customer product images",
      "unredacted production logs",
      "store console pages with account, payment, or identity details"
    ],
    "requiredRedactions": [
      "blur account identifiers when not needed for the test",
      "hide phone numbers, email inboxes, and personal notification content",
      "crop browser address bars only when the origin has already been recorded in the evidence JSON",
      "replace real user uploads with prepared demo assets"
    ],
    "fileNaming": "store/evidence/mobile-device-qa/YYYY-MM-DD/<device-id>/<case-id>-redacted.png"
  },
  "requiredEnvironments": [
    {
      "id": "public-mobile-web",
      "target": "https://www.zkraiflow.top",
      "status": "public-origin-ready-pending-authenticated-user-proof",
      "requiredBefore": [
        "external mobile web pilot",
        "PWA pilot"
      ]
    },
    {
      "id": "review-account",
      "target": "production or review environment",
      "status": "blocked-until-real-review-account",
      "requiredBefore": [
        "authenticated smoke",
        "App Store review",
        "Google Play review"
      ]
    },
    {
      "id": "android-native-build",
      "target": "Capacitor Android package",
      "status": "blocked-until-android-toolchain",
      "requiredBefore": [
        "Google Play submission",
        "native Android screenshots"
      ]
    },
    {
      "id": "ios-native-build",
      "target": "Capacitor iOS package",
      "status": "blocked-until-macos-xcode",
      "requiredBefore": [
        "App Store submission",
        "native iOS screenshots"
      ]
    }
  ],
  "testPacket": {
    "targetTesterCount": 5,
    "minimumNonTechnicalTesterCount": 3,
    "testWindow": "one focused 30-45 minute session per tester",
    "testerBrief": "Ask testers to complete one product-image to prompt/video dry-run path without explaining the UI first.",
    "passDefinition": "A tester can finish the assigned path, find support/legal/data-rights entries, and recover from mistakes without desktop-only instructions."
  },
