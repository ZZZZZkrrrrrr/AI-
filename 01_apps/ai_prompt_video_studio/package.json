{
  "name": "ai-prompt-video-studio",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "api": "node server.js",
    "start": "node server.js",
    "dev": "vite --host 0.0.0.0 --port 5173",
    "build": "vite build && node scripts/check-bundle-budget.mjs",
    "build:report": "npm run build && node scripts/report-bundle-size.mjs",
    "mobile:check": "node scripts/check-mobile-readiness.mjs",
    "mobile:density": "node scripts/check-mobile-operation-density.mjs",
    "mobile:qa": "node scripts/check-mobile-device-qa-plan.mjs && node scripts/check-mobile-qa-evidence-template.mjs",
    "mobile:qa:evidence": "node scripts/check-mobile-qa-evidence-template.mjs",
    "pwa:check": "node scripts/check-pwa-assets.mjs",
    "pwa:prod-plan": "node scripts/check-pwa-production-smoke-plan.mjs && node scripts/check-pwa-device-install-evidence-template.mjs",
    "pwa:device-template": "node scripts/check-pwa-device-install-evidence-template.mjs",
    "pwa:public-smoke": "node scripts/check-pwa-public-smoke.mjs",
    "public:check": "node scripts/check-public-domain-readiness.mjs",
    "owner:brief": "node scripts/generate-release-input-shortlists.mjs",
    "owner:form": "node scripts/generate-owner-input-form.mjs",
    "owner:inputs": "node scripts/check-operator-inputs.mjs",
    "store:check": "node scripts/check-store-readiness.mjs",
    "store:check:strict": "node scripts/check-store-readiness.mjs --strict",
    "store:console-plan": "node scripts/check-store-console-submission-plan.mjs",
    "review:access-plan": "node scripts/check-review-access-plan.mjs",
    "review:seed": "node scripts/seed-review-demo.mjs",
    "review:seed:dry": "node scripts/seed-review-demo.mjs --dry-run",
    "china:distribution-plan": "node scripts/check-china-distribution-plan.mjs",
    "screenshots:check": "node scripts/check-screenshot-plan.mjs",
    "screenshots:check:strict": "node scripts/check-screenshot-plan.mjs --strict",
    "screenshots:native-plan": "node scripts/check-native-screenshot-handoff.mjs",
    "native:release-plan": "node scripts/check-native-release-signing-plan.mjs",
    "screenshots:capture": "npm run build && node scripts/capture-web-screenshots.mjs",
    "capacitor:check": "node scripts/check-capacitor-readiness.mjs",
    "capacitor:sync": "npm run build && npx cap sync",
    "compliance:check": "node scripts/check-compliance-assets.mjs",
    "legal:finalization-plan": "node scripts/check-legal-finalization-plan.mjs",
    "cloud:check": "node scripts/check-cloud-readiness.mjs",
    "cloud:check:strict": "node scripts/check-cloud-readiness.mjs --strict",
    "cloud:worker-contract": "node scripts/check-libtv-worker-contract.mjs",
    "cloud:worker-plan": "node scripts/check-cloud-worker-plan.mjs",
    "cloud:worker-smoke-template": "node scripts/check-libtv-worker-smoke-evidence-template.mjs",
    "storage:restart-template": "node scripts/check-persistent-storage-evidence-template.mjs",
    "production:auth-plan": "node scripts/check-production-auth-cors-plan.mjs",
    "production:ops-plan": "node scripts/check-production-observability-plan.mjs",
    "production:profile": "node scripts/check-production-profile-readiness.mjs",
    "production:smoke-template": "node scripts/check-authenticated-smoke-evidence-template.mjs",
    "production:handoff": "node scripts/generate-production-handoff.mjs",
    "cloud:smoke": "node scripts/production-smoke-test.mjs",
    "release:channels": "node scripts/check-release-channel-plan.mjs",
    "pilot:invite-pack": "node scripts/check-pilot-invite-pack.mjs",
    "pilot:readiness": "node scripts/check-pilot-release-readiness.mjs",
    "pilot:feedback": "node scripts/check-pilot-feedback-readiness.mjs",
    "release:evidence": "node scripts/check-release-evidence-register.mjs",
    "launch:cockpit": "node scripts/generate-launch-cockpit.mjs",
    "product:report": "node scripts/report-productization-readiness.mjs",
    "analyze:app": "node scripts/report-app-structure.mjs",
    "app:health": "npm run mobile:check && npm run mobile:density && npm run pwa:check && npm run analyze:app && npm run build:report && npm run capacitor:check",
    "release:check": "npm run compliance:check && npm run legal:finalization-plan && npm run cloud:check:strict && npm run cloud:worker-contract && npm run cloud:worker-plan && npm run cloud:worker-smoke-template && npm run storage:restart-template && npm run production:auth-plan && npm run production:ops-plan && npm run production:profile && npm run production:smoke-template && npm run production:handoff && npm run public:check && npm run owner:brief && npm run owner:form && npm run owner:inputs && npm run pwa:prod-plan && npm run pwa:public-smoke && npm run release:channels && npm run pilot:invite-pack && npm run pilot:readiness && npm run pilot:feedback && npm run screenshots:check && npm run screenshots:native-plan && npm run native:release-plan && npm run mobile:qa && npm run store:check && npm run store:console-plan && npm run release:evidence && npm run review:access-plan && npm run review:seed:dry && npm run china:distribution-plan && npm run launch:cockpit && npm run product:report && npm run app:health",
    "preview": "vite preview --host 0.0.0.0 --port 5173"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/core": "^8.4.0",
    "@capacitor/ios": "^8.4.0",
    "@vitejs/plugin-react": "^5.1.1",
    "lucide-react": "^0.468.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "vite": "^7.2.4",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.0"
  }
}
