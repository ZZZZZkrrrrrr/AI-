# Production deployment profile for AI Video Studio.
# Copy values into your hosting platform's secret/environment settings.
# Do not commit real API keys, passwords, or internal endpoints.

NODE_ENV=production
PORT=3001

# Public web/PWA origin. Use the real HTTPS domain users open in the browser.
PUBLIC_APP_ORIGIN=https://app.example.com

# Add only the origins that should call authenticated APIs.
# Keep capacitor://localhost and https://localhost only when the packaged app
# calls this remote API directly from its WebView.
CORS_ALLOWED_ORIGINS=https://app.example.com,capacitor://localhost,https://localhost
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_LOCALHOST=false

# Login protection.
CONSOLE_AUTH_REQUIRED=true
CONSOLE_AUTH_USER=admin@example.com
CONSOLE_AUTH_PASSWORD=
CONSOLE_AUTH_PASSWORD_SHA256=change-me-sha256
CONSOLE_AUTH_ALLOW_REGISTRATION=false
CONSOLE_AUTH_SESSION_HOURS=24

# Same-origin web/PWA can use Lax. Capacitor remote-API login usually needs
# SameSite=None plus Secure=true.
CONSOLE_AUTH_COOKIE_SECURE=true
CONSOLE_AUTH_COOKIE_SAMESITE=Lax

# AI providers.
QIANWEN_API_KEY=
QIANWEN_MODEL=qwen3.6-plus
QIANWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QIANWEN_VL_API_KEY=
QIANWEN_VL_MODEL=qwen3-vl-flash
ARK_API_KEY=
SEEDANCE_API_URL=https://ark.cn-beijing.volces.com/api/v3/contents/generations/tasks
SEEDANCE_MODEL=doubao-seedance-2-0-fast-260128
DOUBAO_SEED_PRO_API_URL=https://ark.cn-beijing.volces.com/api/v3/chat/completions
DOUBAO_SEED_PRO_MODEL=doubao-seed-2-0-pro-260215
SEEDREAM_API_URL=https://ark.cn-beijing.volces.com/api/v3/images/generations
SEEDREAM_MODEL=doubao-seedream-4-5-251128

# Runtime limits.
BATCH_MAX_WORKERS=3
MODEL_REQUEST_TIMEOUT_MS=360000

# Persistent storage and external tools.
RUN_STORAGE_DIR=/var/lib/ai-video-studio/runs
PYTHON_EXE=python3
FFMPEG_EXE=ffmpeg

# libTV should be moved behind a worker/private service before public launch.
LIBTV_BRIDGE_URL=https://libtv-worker.internal.example.com
LIBTV_REGISTER_SCRIPT=/app/services/libtv_runner/register_task_input.py
LIBTV_DB_PATH=/data/ai_ugc_product.sqlite
LIBTV_DEFAULT_DRY_RUN=false
LIBTV_AUTO_COMPLIANCE=true
LIBTV_SEARCH_ENABLED=true

# Deployment smoke test inputs. These are used by npm run cloud:smoke,
# not by the running server process.
SMOKE_BASE_URL=https://app.example.com
SMOKE_USERNAME=
SMOKE_PASSWORD=
SMOKE_EXPECT_AUTH_REQUIRED=true
SMOKE_TIMEOUT_MS=15000
