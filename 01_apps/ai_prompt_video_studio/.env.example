# Copy this file to .env and fill in your real keys locally.
# Do not put real API keys into frontend files.

# Qianwen text
QIANWEN_API_KEY=
QIANWEN_MODEL=qwen3.6-plus
QIANWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Qianwen vision, used to convert product images into structured product facts.
QIANWEN_VL_API_KEY=
QIANWEN_VL_MODEL=qwen3-vl-flash

# Volcengine Ark
ARK_API_KEY=

# Seedance video generation.
SEEDANCE_API_URL=https://ark.cn-beijing.volces.com/api/v3/contents/generations/tasks
SEEDANCE_MODEL=doubao-seedance-2-0-fast-260128

# Doubao chat, used for the ten-step SOP execution and final prompt packaging.
DOUBAO_SEED_PRO_API_URL=https://ark.cn-beijing.volces.com/api/v3/chat/completions
DOUBAO_SEED_PRO_MODEL=doubao-seed-2-0-pro-260215

# Seedream image generation, reserved for later flat-asset generation.
SEEDREAM_API_URL=https://ark.cn-beijing.volces.com/api/v3/images/generations
SEEDREAM_MODEL=doubao-seedream-4-5-251128

# Optional comma-separated model IDs shown in the frontend model switcher.
ANALYSIS_MODEL_OPTIONS=qwen3.6-plus,doubao-seed-2-0-pro-260215
VISION_MODEL_OPTIONS=qwen3-vl-flash,qwen3-vl-plus,qwen3-vl-flash-2025-10-15,qwen3-vl-plus-2025-09-23,qwen3-vl-235b-a22b-instruct,qwen3-vl-235b-a22b-thinking
VIDEO_MODEL_OPTIONS=Seedance 2.0 Fast VIP,Seedance 2.0 VIP,Seedance1.5 Pro
IMAGE_GENERATION_MODEL_OPTIONS=doubao-seedream-4-5-251128

# libTV local bridge. The HTML app writes a task into SQLite, then calls this bridge.
# For cloud deployment, replace localhost and Windows paths with a worker service,
# managed database, mounted volume, or object storage backed job runner.
LIBTV_BRIDGE_URL=http://127.0.0.1:8799
LIBTV_REGISTER_SCRIPT=D:\Organized\Projects\codex_project\workflow\02_services\libtv_runner\register_task_input.py
LIBTV_DB_PATH=D:\Organized\Projects\codex_project\workflow\03_database\ai_database\ai_product.sqlite
LIBTV_DEFAULT_DRY_RUN=true
LIBTV_ENABLE_SOUND=true
LIBTV_AUTO_COMPLIANCE=true
LIBTV_SEARCH_ENABLED=true
# Reuse one canvas project under LibTV's Video section. Each task becomes a separate group.
LIBTV_SHARED_PROJECT_NAME=AI视频工作台
LIBTV_SHARED_PROJECT_UUID=

# Batch concurrency limit. Keep the first public release conservative.
BATCH_MAX_WORKERS=3

# Runtime storage and external tools.
RUN_STORAGE_DIR=
PYTHON_EXE=py
FFMPEG_EXE=ffmpeg
MODEL_REQUEST_TIMEOUT_MS=360000

NODE_ENV=development
PORT=3001

# Public web/App origins.
# Production should use your real HTTPS domain, for example:
# PUBLIC_APP_ORIGIN=https://app.example.com
# CORS_ALLOWED_ORIGINS=https://app.example.com,capacitor://localhost,https://localhost
PUBLIC_APP_ORIGIN=http://localhost:3001
CORS_ALLOWED_ORIGINS=http://localhost:3001,http://localhost:5173,capacitor://localhost,https://localhost
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_LOCALHOST=true

# Login protection for the web console.
# For public domain access, keep this enabled and set your own password locally.
CONSOLE_AUTH_REQUIRED=true
CONSOLE_AUTH_USER=zkr
CONSOLE_AUTH_PASSWORD=
# Prefer CONSOLE_AUTH_PASSWORD_SHA256 in managed hosting if you do not want to store
# a plaintext console password in environment variables.
CONSOLE_AUTH_PASSWORD_SHA256=
CONSOLE_AUTH_ALLOW_REGISTRATION=false
CONSOLE_AUTH_SESSION_HOURS=24
# For public HTTPS deployment, set CONSOLE_AUTH_COOKIE_SECURE=true.
# Capacitor apps that call a remote API may need SameSite=None plus Secure=true.
CONSOLE_AUTH_COOKIE_SECURE=false
CONSOLE_AUTH_COOKIE_SAMESITE=Lax


