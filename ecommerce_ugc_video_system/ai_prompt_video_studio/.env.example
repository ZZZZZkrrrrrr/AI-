# Copy this file to .env and fill in your real keys locally.
# Do not put real API keys into frontend files.

# Qianwen text
QIANWEN_API_KEY=
QIANWEN_MODEL=qwen3.6-plus
QIANWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Qianwen vision, used to convert product images into structured product facts.
QIANWEN_VL_API_KEY=
QIANWEN_VL_MODEL=qwen3-vl-flash

# Volcengine Ark
ARK_API_KEY=

# Doubao chat, used for the ten-step SOP execution and final prompt packaging.
DOUBAO_SEED_PRO_API_URL=https://ark.cn-beijing.volces.com/api/v3/chat/completions
DOUBAO_SEED_PRO_MODEL=doubao-seed-2-0-pro-260215

# Seedream image generation, reserved for later flat-asset generation.
SEEDREAM_API_URL=https://ark.cn-beijing.volces.com/api/v3/images/generations
SEEDREAM_MODEL=doubao-seedream-4-5-251128

# Optional comma-separated model IDs shown in the frontend model switcher.
ANALYSIS_MODEL_OPTIONS=qwen3.6-plus,doubao-seed-2-0-pro-260215
VISION_MODEL_OPTIONS=qwen3-vl-flash,qwen3-vl-plus,qwen3-vl-flash-2025-10-15,qwen3-vl-plus-2025-09-23,qwen3-vl-235b-a22b-instruct,qwen3-vl-235b-a22b-thinking
VIDEO_MODEL_OPTIONS=doubao-seedance-2-0-fast-260128
IMAGE_GENERATION_MODEL_OPTIONS=doubao-seedream-4-5-251128

# libTV local bridge. The HTML app writes a task into SQLite, then calls this bridge.
LIBTV_BRIDGE_URL=http://127.0.0.1:8799
LIBTV_REGISTER_SCRIPT=D:\Organized\Projects\codex_project\workflow\libtv_runner\register_task_input.py
LIBTV_DB_PATH=D:\Organized\Projects\codex_project\workflow\ai_ugc_database\ai_ugc_product.sqlite
LIBTV_DEFAULT_DRY_RUN=true

PORT=3001
